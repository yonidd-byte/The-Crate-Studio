# =========================================================
# The Crate Studio — JUCE + Tracktion Engine .gitignore
# =========================================================

# ---- CMake build dirs ----
build/
build-*/
out/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
CMakeScripts/
cmake_install.cmake
install_manifest.txt
compile_commands.json
_deps/

# ---- Projucer-generated (JUCE) ----
# If any modules still use Projucer instead of pure CMake
JuceLibraryCode/
Builds/
*.jucer.bak

# ---- Tracktion Engine / JUCE submodule internals ----
# (Vendored via git submodule — do not track build artifacts inside them)
modules/*/build/
modules/*/Builds/

# ---- Compiled binaries / objects ----
*.o
*.obj
*.lo
*.slo
*.a
*.lib
*.la
*.lai
*.so
*.so.*
*.dylib
*.dll
*.exe
*.pdb
*.ilk
*.exp
*.map
*.node

# ---- Audio plugin bundles (build output) ----
*.vst3
*.component
*.clap
*.aaxplugin
*.app/

# ---- IDE / editor specific ----
.vs/
.vscode/
*.user
*.suo
*.sdf
*.opensdf
*.VC.db
*.VC.VC.opendb
*.xcodeproj/
*.xcworkspace/
xcuserdata/
DerivedData/
.idea/
*.iml
*.swp
*~
.DS_Store
Thumbs.db
desktop.ini

# ---- Visual Studio ----
*.vcxproj.user
*.aps
*.ncb
*.opendb
ipch/
*.tlog
*.log
Debug/
Release/
x64/
x86/
[Ww]in32/

# ---- JUCE audio plugin host state / cached scans ----
*.settings
JucePluginDefines.h

# ---- Package managers / fetch content caches ----
.cpm-cache/
_FetchContent/

# ---- Misc ----
*.tmp
*.bak
*.orig
build/
.vs/
